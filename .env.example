# Tack — environment variables
#
# Both of these are PUBLIC. They're inlined into the client bundle at build time
# (that's why they're NEXT_PUBLIC_*). Security is enforced in Postgres via RLS,
# not by hiding these values. Do NOT add a service-role key to this app.
#
# Where to get them:
#   Supabase dashboard → Project Settings → API
#     - Project URL          → NEXT_PUBLIC_SUPABASE_URL
#     - Project API keys     → NEXT_PUBLIC_SUPABASE_ANON_KEY
#       (use the "publishable" key on new projects, or the legacy "anon" key)
#
# After copying this file to `.env`, also add these redirect URLs in Supabase:
#   Authentication → URL Configuration → Redirect URLs
#     http://localhost:3000/auth/callback
#     https://YOUR-DOMAIN/auth/callback

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Canonical site URL — used for SEO canonical tags, sitemap, robots, and
# absolute Open Graph / link-preview image URLs. No trailing slash.
# Set this to your real production domain before deploying.
NEXT_PUBLIC_SITE_URL=https://tack.app

# ---------------------------------------------------------------------------
# Email (OPTIONAL) — app notifications (welcome, board invites) via Resend.
#
# Unlike the values above, this is a SERVER-SIDE SECRET. Leave it unset and
# email is simply disabled — every notification becomes a quiet no-op. The
# magic-link sign-in email is sent by Supabase over its own SMTP, NOT by this.
#
# For production on Cloudflare set it as a runtime secret instead of here:
#   npx wrangler secret put RESEND_API_KEY
# For local dev, put it in `.dev.vars` (gitignored). See docs/EMAIL.md.
#
# RESEND_API_KEY=re_your_key
# RESEND_FROM=Tack <hello@your-verified-domain.com>
