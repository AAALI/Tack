# Tack — environment variables
#
# Both of these are PUBLIC. They're inlined into the client bundle at build time
# (that's why they're NEXT_PUBLIC_*). Security is enforced in Postgres via RLS,
# not by hiding these values. Do NOT add a service-role key to this app.
#
# Where to get them:
#   Supabase dashboard → Project Settings → API
#     - Project URL          → NEXT_PUBLIC_SUPABASE_URL
#     - Project API keys     → NEXT_PUBLIC_SUPABASE_ANON_KEY
#       (use the "publishable" key on new projects, or the legacy "anon" key)
#
# After copying this file to `.env`, also add these redirect URLs in Supabase:
#   Authentication → URL Configuration → Redirect URLs
#     http://localhost:3000/auth/callback
#     https://YOUR-DOMAIN/auth/callback

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
